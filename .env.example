# =============================================================================
# Agentic Talent Matcher — Application Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.
# =============================================================================

# --- Application ---
APP_PORT=8000
APP_HOST=0.0.0.0

# --- LLM ---
# Format: provider:model_name
# Supported providers: openai, google (gemini), anthropic (claude)
# Example providers:
#   LLM_MODEL_NAME=openai:gpt-4o-mini
#   LLM_MODEL_NAME=google:gemini-2.5-flash
#   LLM_MODEL_NAME=anthropic:claude-sonnet-4-20250514
#   LLM_MODEL_NAME=ollama:gemma2:2b
#   LLM_MODEL_NAME=local:gemma-2-9b-it (e.g. via LM Studio)
LLM_MODEL_NAME=openai:gpt-4o-mini
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=
LLM_TEMPERATURE=0

# --- Embedding / Semantic Chunker ---
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
SPARSE_EMBEDDING_MODEL_NAME=prithivida/Splade_PP_en_v1
CHUNKER_MODEL_NAME=all-MiniLM-L6-v2
CHUNKER_BREAKPOINT_TYPE=percentile

# --- Vector Store ---
VECTOR_STORE_COLLECTION=candidates
