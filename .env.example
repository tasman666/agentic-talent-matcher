# =============================================================================
# Agentic Talent Matcher — Application Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.
# =============================================================================

# --- Application ---
APP_PORT=8000
APP_HOST=0.0.0.0

# --- LLM (OpenAI-compatible) ---
LLM_MODEL_NAME=gpt-4o-mini
LLM_API_KEY=your-openai-api-key-here
LLM_TEMPERATURE=0

# --- Embedding / Semantic Chunker ---
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
SPARSE_EMBEDDING_MODEL_NAME=prithivida/Splade_PP_en_v1
CHUNKER_MODEL_NAME=all-MiniLM-L6-v2
CHUNKER_BREAKPOINT_TYPE=percentile

# --- Vector Store ---
VECTOR_STORE_COLLECTION=candidates
